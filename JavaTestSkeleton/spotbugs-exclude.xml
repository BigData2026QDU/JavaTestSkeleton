<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter>
    <!-- 排除测试代码 -->
    <Match>
        <Class name="~.*Test$"/>
    </Match>
    <Match>
        <Class name="~.*IT$"/>
    </Match>
    <Match>
        <Class name="~.*Test\$.*"/>
    </Match>

    <!-- 排除 submodule 项目代码（外部维护） -->
    <Match>
        <Class name="~org\.example\.Tool\..*"/>
    </Match>
    <Match>
        <Class name="~org\.example\.Service\..*"/>
    </Match>

    <!-- 排除测试实体 -->
    <Match>
        <Class name="TestItem"/>
    </Match>

    <!-- 排除自动生成的代码 -->
    <Match>
        <Class name="~.*\$\$.*"/>
    </Match>
</FindBugsFilter>
