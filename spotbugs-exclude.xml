<?xml version="1.0" encoding="UTF-8"?>
<!--
    SpotBugs 排除规则
    排除测试代码和已知误报
-->
<FindBugsFilter>
    <!-- 排除测试代码 -->
    <Match>
        <Class name="~.*Test$"/>
    </Match>
    <Match>
        <Class name="~.*IT$"/>
    </Match>
    <Match>
        <Class name="~.*Test\$.*"/>
    </Match>

    <!-- 排除自动生成的代码 -->
    <Match>
        <Class name="~.*\$\$.*"/>
    </Match>
</FindBugsFilter>
